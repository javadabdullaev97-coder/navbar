# Navbar — пример переменных окружения. Реальные значения НИКОГДА не коммитим (CLAUDE.md §9).
# Скопируй в .env.local (клиенты) / .env (сервер) и заполни своими значениями.

# ── Supabase (клиент) ─────────────────────────────────────────
# Публичные: уходят в web/mobile-бандл, защищены RLS.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Supabase (сервер) ─────────────────────────────────────────
# СЕКРЕТ: только на сервере / в edge functions. НИКОГДА в клиент-бандл.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.YOUR-PROJECT.supabase.co:5432/postgres

# ── Внешние интеграции (этап подключений) ─────────────────────
TELEGRAM_BOT_TOKEN=
PAYME_MERCHANT_ID=
PAYME_KEY=
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET=
# SMS fallback
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
